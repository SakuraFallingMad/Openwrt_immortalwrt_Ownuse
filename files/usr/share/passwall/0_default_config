
config global
	option enabled '0'
	option socks_enabled '0'
	option tcp_node 'nil'
	option udp_node 'nil'
	option tcp_node_socks_port '1070'
	option dns_mode 'dns2tcp'
	option remote_dns '127.0.0.1:7053'
	option filter_proxy_ipv6 '0'
	option when_chnroute_default_dns 'direct'
	option tcp_proxy_mode 'chnroute'
	option udp_proxy_mode 'chnroute'
	option chinadns_ng_default_tag 'smart'
	option localhost_tcp_proxy_mode 'default'
	option localhost_udp_proxy_mode 'default'
	option acl_enable '0'
	option close_log_tcp '0'
	option close_log_udp '0'
	option loglevel 'error'
	option trojan_loglevel '4'

config global_haproxy
	option balancing_enable '0'

config global_delay
	option auto_on '0'
	option start_daemon '1'
	option start_delay '60'

config global_forwarding
	option tcp_no_redir_ports 'disable'
	option udp_no_redir_ports 'disable'
	option tcp_proxy_drop_ports 'disable'
	option udp_proxy_drop_ports '443'
	option tcp_redir_ports '22,25,53,143,465,587,853,993,995,80,443'
	option udp_redir_ports '1:65535'
	option accept_icmp '1'
	option accept_icmpv6 '1'
	option use_nft '1'
	option tcp_proxy_way 'tproxy'
	option ipv6_tproxy '1'

config global_xray
	option sniffing '1'
	option route_only '0'

config global_singbox
	option sniff_override_destination '0'
	option geoip_path '/usr/share/singbox/geoip.db'
	option geoip_url 'https://cdn.jsdelivr.net/gh/1715173329/sing-geoip@releases/latest/download/geoip.db'
	option geosite_path '/usr/share/singbox/geosite.db'
	option geosite_url 'https://cdn.jsdelivr.net/gh/1715173329/sing-geosite@releases/latest/download/geosite.db'

config global_other
	option nodes_ping 'auto_ping tcping'

config global_rules
	option auto_update '0'
	option chnlist_update '1'
	option chnroute_update '1'
	option chnroute6_update '1'
	option gfwlist_update '1'
	option geosite_update '1'
	option geoip_update '1'
	list gfwlist_url 'https://cdn.jsdelivr.net/gh/pmkol/easymosdns@rules/gfw_domain_list.txt'
	list chnroute_url 'https://cdn.jsdelivr.net/gh/misakaio/chnroutes2@master/chnroutes.txt'
	list chnroute_url 'https://cdn.jsdelivr.net/gh/pexcn/daily@gh-pages/chnroute/chnroute.txt'
	list chnroute_url 'https://cdn.jsdelivr.net/gh/gaoyifan/china-operator-ip@ip-lists/china.txt'
	list chnroute6_url 'https://cdn.jsdelivr.net/gh/pexcn/daily@gh-pages/chnroute/chnroute6.txt'
	list chnroute6_url 'https://cdn.jsdelivr.net/gh/gaoyifan/china-operator-ip@ip-lists/china6.txt'
	list chnlist_url 'https://cdn.jsdelivr.net/gh/pmkol/easymosdns@rules/china_domain_list.txt'
	option v2ray_location_asset '/usr/share/v2ray/'

config global_app
	option singbox_file '/usr/bin/sing-box'
	option xray_file '/usr/bin/xray'
	option trojan_go_file '/usr/bin/trojan-go'
	option brook_file '/usr/bin/brook'
	option hysteria_file '/usr/bin/hysteria'
	option chinadns_ng '/usr/bin/chinadns-ng'

config global_subscribe
	option filter_keyword_mode '1'
	list filter_discard_list '过期时间'
	list filter_discard_list '剩余流量'
	list filter_discard_list 'QQ群'
	list filter_discard_list '官网'
	list filter_discard_list '续费'

config nodes 'myshunt'
	option remarks '分流总节点'
	option type 'Xray'
	option protocol '_shunt'
	option Force_Reject '_blackhole'
	option Force_Direct '_direct'
	option Direct_Game '_direct'
	option Proxy_Game 'nil'
	option OpenAI 'nil'
	option Telegram 'nil'
	option YouTube 'nil'
	option Netflix 'nil'
	option TVB 'nil'
	option China 'nil'
	option default_node 'nil'
	option domainStrategy 'AsIs'
	option domainMatcher 'hybrid'

